{
  "project_context": {
    "problem_statement": "成熟推理框架过于臃肿，包含大量多模型、多部署、多策略的动态分派与条件分支，降低可维护性与性能。",
    "goal": "构建小而美、功能单一、流程清晰、可由 Agent 自动生成的定制化推理框架，并针对 DeepSeek V2 Chat 在固定环境下跑通真实推理闭环。",
    "source": [
      "notebooks/tasks.md",
      "notebooks/MEMORY.md",
      "notebooks/00_overview/README.md"
    ]
  },
  "model_profile": {
    "name": "deepseek-v2-chat-pytorch-16b",
    "model_dir": "/data/xinference/cache/deepseek-v2-chat-pytorch-16b",
    "dtype_runtime": "torch.bfloat16",
    "config": {
      "hidden_size": 2048,
      "num_hidden_layers": 27,
      "num_attention_heads": 16,
      "num_key_value_heads": 16,
      "kv_lora_rank": 512,
      "qk_nope_head_dim": 128,
      "qk_rope_head_dim": 64,
      "v_head_dim": 128,
      "n_routed_experts": 64,
      "n_shared_experts": 2,
      "num_experts_per_tok": 6,
      "moe_intermediate_size": 1408,
      "first_k_dense_replace": 1,
      "eos_token_id": 100001,
      "vocab_size": 102400
    },
    "mla_kv_materialized_formula": "bytes_per_token = num_hidden_layers * num_attention_heads * (qk_nope_head_dim + qk_rope_head_dim + v_head_dim) * dtype_bytes",
    "mla_kv_materialized_bytes_per_token_bf16": 276480
  },
  "components": [
    {
      "name": "Scheduler",
      "role": "执行 prefill/decode 连续批调度；prefill 优先；资源不足时只排队不抢占；在 postprocess 中推进状态并触发 token 级块扩展。",
      "ref_docs": [
        "notebooks/01_framework_design/02_scheduler.md",
        "notebooks/01_framework_design/07_request_lifecycle.md"
      ],
      "ref_code": [
        "ref_projects/nano-vllm/nanovllm/engine/scheduler.py"
      ],
      "impl_code": [
        "engine/scheduler.py"
      ]
    },
    {
      "name": "KVMemoryPool",
      "role": "管理 KV 逻辑块容量、块分配/释放与可扩展性检查；基于 HF 配置估算 DeepSeek V2 MLA 的 KV 字节预算；提供可选 GPU KV 占位张量。",
      "ref_docs": [
        "notebooks/01_framework_design/03_kv_cache.md",
        "notebooks/01_framework_design/06_memory_pool.md"
      ],
      "ref_code": [
        "ref_projects/nano-vllm/nanovllm/engine/block_manager.py",
        "ref_projects/nano-vllm/nanovllm/engine/model_runner.py"
      ],
      "impl_code": [
        "engine/memory_pool.py",
        "engine/kv_specs.py"
      ]
    },
    {
      "name": "BlockManager",
      "role": "分页块分配器；维护 free/used block 集合；通过链式哈希执行 prefix caching 与 ref_count 共享；支持 may_append 增量扩展。",
      "ref_docs": [
        "notebooks/01_framework_design/03_kv_cache.md"
      ],
      "ref_code": [
        "ref_projects/nano-vllm/nanovllm/engine/block_manager.py"
      ],
      "impl_code": [
        "engine/block_manager.py"
      ]
    },
    {
      "name": "ModelRunner",
      "role": "加载真实 HF 模型与 tokenizer；执行 prefill/decode 前向并调用采样器输出 next token。",
      "ref_docs": [
        "notebooks/01_framework_design/04_model_runner.md",
        "notebooks/01_framework_design/07_request_lifecycle.md"
      ],
      "ref_code": [
        "ref_projects/nano-vllm/nanovllm/engine/model_runner.py"
      ],
      "impl_code": [
        "llm_engine.py::RealModelRunner"
      ]
    },
    {
      "name": "Sampler",
      "role": "根据 temperature/top_p 执行 greedy 或随机采样，将 logits 转换为 token ids。",
      "ref_docs": [
        "notebooks/01_framework_design/05_sampler.md"
      ],
      "ref_code": [
        "ref_projects/nano-vllm/nanovllm/layers/sampler.py"
      ],
      "impl_code": [
        "engine/sampler.py"
      ]
    },
    {
      "name": "Sequence",
      "role": "请求级状态容器：维护 input/output token、block_table、缓存 token 计数、状态机转移与分块视图。",
      "ref_docs": [
        "notebooks/01_framework_design/01_architecture.md",
        "notebooks/01_framework_design/07_request_lifecycle.md"
      ],
      "ref_code": [
        "ref_projects/nano-vllm/nanovllm/engine/sequence.py"
      ],
      "impl_code": [
        "engine/structs.py"
      ]
    },
    {
      "name": "LLMEngine",
      "role": "系统编排器：初始化 Runner/MemoryPool/Scheduler，驱动 while-loop 直到所有序列完成并解码文本。",
      "ref_docs": [
        "notebooks/01_framework_design/01_architecture.md",
        "notebooks/01_framework_design/07_request_lifecycle.md"
      ],
      "ref_code": [
        "ref_projects/nano-vllm/nanovllm/engine/llm_engine.py"
      ],
      "impl_code": [
        "llm_engine.py::LLMEngine"
      ]
    }
  ],
  "data_flow_contracts": {
    "request_level": {
      "sequence_fields": {
        "input_ids": "list[int]",
        "output_ids": "list[int]",
        "token_ids": "input_ids + output_ids",
        "block_table": "list[int]",
        "num_cached_tokens": "int",
        "status": "WAITING|RUNNING_PREFILL|RUNNING_DECODE|FINISHED"
      },
      "status_transitions": [
        "WAITING -> RUNNING_PREFILL",
        "RUNNING_PREFILL -> RUNNING_DECODE",
        "RUNNING_DECODE -> FINISHED"
      ]
    },
    "scheduler_to_runner": {
      "batch_type": "list[Sequence]",
      "prefill_trigger": "schedule() 优先从 waiting 组 batch；必须满足 max_num_batched_tokens 与 can_allocate",
      "decode_trigger": "waiting 无可调度项时，从 running 中选择 can_append_one_more 的序列",
      "preemption_policy": "disabled; 资源不足时不抢占，只等待"
    },
    "runner_prefill_tensors": {
      "input_ids": {
        "shape": "[1, L_prompt] per sequence",
        "dtype": "torch.int64",
        "device": "cuda"
      },
      "hf_forward": {
        "call": "model(input_ids=ids, use_cache=False, return_dict=True)",
        "logits_shape": "[1, L_prompt, vocab_size]"
      },
      "sampling_input": {
        "shape": "[1, vocab_size]",
        "source": "logits[0, -1, :].unsqueeze(0)"
      },
      "sampling_output": {
        "shape": "[1]",
        "dtype": "torch.int64"
      }
    },
    "runner_decode_tensors": {
      "input_ids": {
        "shape": "[B, L_max] (left padding)",
        "dtype": "torch.int64",
        "device": "cuda"
      },
      "attention_mask": {
        "shape": "[B, L_max]",
        "dtype": "torch.int64",
        "device": "cuda",
        "rule": "pad=0, valid_token=1"
      },
      "hf_forward": {
        "call": "model(input_ids=ids, attention_mask=m, use_cache=False, return_dict=True)",
        "logits_shape": "[B, L_max, vocab_size]"
      },
      "sampling_input": {
        "shape": "[B, vocab_size]",
        "source": "logits[:, -1, :]"
      },
      "sampling_output": {
        "shape": "[B]",
        "dtype": "torch.int64"
      }
    },
    "deepseek_v2_mla_kv_contract": {
      "config_dims": {
        "kv_lora_rank": 512,
        "qk_nope_head_dim": 128,
        "qk_rope_head_dim": 64,
        "q_head_dim": 192,
        "v_head_dim": 128,
        "num_attention_heads": 16,
        "num_hidden_layers": 27
      },
      "hf_materialized_kv_shapes_per_layer": {
        "key_states": "[batch, num_heads, q_len, q_head_dim] -> [batch, 16, q_len, 192]",
        "value_states": "[batch, num_heads, q_len, v_head_dim] -> [batch, 16, q_len, 128]"
      },
      "logical_kv_bytes": {
        "formula": "num_layers * num_heads * (q_head_dim + v_head_dim) * dtype_bytes",
        "dtype_bfloat16_bytes_per_token": 276480,
        "bytes_per_block_block_size_16": 4423680
      },
      "physical_block_indexing": {
        "token_to_block": "block_index = token_pos // block_size",
        "token_offset": "offset = token_pos % block_size",
        "slot_id": "slot_id = block_table[block_index] * block_size + offset",
        "block_table_dtype": "python list[int] (若转 tensor 用 int32)"
      },
      "device_dtype_requirements": {
        "runner_inputs": "int64 on cuda",
        "model_weights": "bfloat16 on cuda",
        "kv_placeholder": "bfloat16 on cuda",
        "sampler_logits_compute": "logits.float() before temperature/top_p"
      }
    }
  },
  "logic_constraints": [
    "当前 RealModelRunner 固定 use_cache=False（为规避部分 transformers 与远程 modeling_deepseek 的 DynamicCache API 不兼容）。",
    "KVMemoryPool 的 block 数按 DeepSeek V2 MLA 真实配置估算，且预留 reserve_bytes 与 mem_utilization 安全因子。",
    "KVMemoryPool 物理 kv_storage 为占位缓冲，不直接绑定 HF attention kernel；逻辑容量与 block_manager 对齐。",
    "Prefix caching 仅对“完整 block token 切片”生效；末尾不满 block 的 token 不入 hash_to_block_id。",
    "Scheduler 采用 prefill 优先策略；decode 仅选择 can_append_one_more 的运行序列，资源不足时不抢占。",
    "Postprocess(prefill) 会写入 prefill 采样得到的首 token，并立即触发 may_append 校验容量。",
    "任务完成标准：python -m pytest tests/test_real_inference.py 通过，且终端出现 16B 模型可读文本输出。",
    "开发约束：严格 TDD，新增或修改组件必须先写测试后实现；未通过单测禁止继续跨组件集成。"
  ]
}
