    "data_flow_contracts": {
    "request_level": {
      "sequence_fields": {
        "input_ids": "list[int]",
        "output_ids": "list[int]",
        "token_ids": "input_ids + output_ids",
        "block_table": "list[int]",
        "num_cached_tokens": "int",
        "status": "WAITING|RUNNING_PREFILL|RUNNING_DECODE|FINISHED"
      },
      "status_transitions": [
        "WAITING -> RUNNING_PREFILL",
        "RUNNING_PREFILL -> RUNNING_DECODE",
        "RUNNING_DECODE -> FINISHED"
      ]
    },
    "scheduler_to_runner": {
      "batch_type": "list[Sequence]",
      "prefill_trigger": "schedule() 优先从 waiting 组 batch；必须满足 max_num_batched_tokens 与 can_allocate",
      "decode_trigger": "waiting 无可调度项时，从 running 中选择 can_append_one_more 的序列",
      "preemption_policy": "disabled; 资源不足时不抢占，只等待"
    },
    "runner_prefill_tensors": {
      "input_ids": {
        "shape": "[1, L_prompt] per sequence",
        "dtype": "torch.int64",
        "device": "cuda"
      },
      "forward_call": "model(input_ids=ids, use_cache=False, return_dict=True)",
      "logits_shape": "[1, L_prompt, vocab_size]",
      "sampling_input": {
        "shape": "[1, vocab_size]",
        "source": "logits[0, -1, :].unsqueeze(0)"
      },
      "sampling_output": {
        "shape": "[1]",
        "dtype": "torch.int64"
      }
    },
    "runner_decode_tensors": {
      "input_ids": {
        "shape": "[B, L_max] (left padding)",
        "dtype": "torch.int64",
        "device": "cuda"
      },
      "attention_mask": {
        "shape": "[B, L_max]",
        "dtype": "torch.int64",
        "device": "cuda",
        "rule": "pad=0, valid_token=1"
      },
      "forward_call": "model(input_ids=ids, attention_mask=m, use_cache=False, return_dict=True)",
      "logits_shape": "[B, L_max, vocab_size]",
      "sampling_input": {
        "shape": "[B, vocab_size]",
        "source": "logits[:, -1, :]"
      },
      "sampling_output": {
        "shape": "[B]",
        "dtype": "torch.int64"
      }
    },
    "tp_layer_interface_contracts": {
      "tp_distributed_runtime": {
        "source_impl": [
          "engine/tp_layers/distributed.py"
        ],
        "rank_size_contract": {
          "tp_rank": "dist.get_rank() or env RANK",
          "tp_size": "dist.get_world_size() or env WORLD_SIZE"
        },
        "collectives": {
          "all_reduce_sum": "输入输出同 shape；fp16/bf16 先转 fp32 归约再 cast 回",
          "all_gather_last_dim": "输入 [..., local_dim] -> 输出 [..., local_dim * tp_size]"
        }
      },
      "tp_embedding_and_lm_head": {
        "source_impl": [
          "engine/tp_layers/embedding.py"
        ],
        "vocab_parallel_embedding": {
          "input_ids": "[B, T] int64",
          "local_weight": "[vocab_size/tp, hidden_size]",
          "local_embedding": "[B, T, hidden_size] (masked local vocab)",
          "output_after_all_reduce": "[B, T, hidden_size]"
        },
        "parallel_lm_head": {
          "input_hidden": "[B, T, hidden_size]",
          "local_logits": "[B, T, vocab_size/tp]",
          "output_logits_gather": "[B, T, vocab_size]"
        }
      },
      "tp_linear_layers": {
        "source_impl": [
          "engine/tp_layers/linear.py"
        ],
        "column_parallel_linear": {
          "weight_shape": "[out/tp, in]",
          "input": "[B, T, in]",
          "output_no_gather": "[B, T, out/tp]",
          "output_with_gather": "[B, T, out]"
        },
        "row_parallel_linear": {
          "weight_shape": "[out, in/tp]",
          "input": "[B, T, in/tp]",
          "partial_output": "[B, T, out]",
          "output_after_all_reduce": "[B, T, out]"
        }
      },
      "qwen3_tp_model_interfaces": {
        "source_impl": [
          "engine/models/qwen.py"
        ],
        "decoder_input_hidden": "[B, T, hidden_size]",
        "attention": {
          "q_local": "[B, T, num_heads/tp, head_dim]",
          "k_local": "[B, T, num_kv_heads_local, head_dim]",
          "v_local": "[B, T, num_kv_heads_local, head_dim]",
          "attn_out_local": "[B, T, num_heads/tp * head_dim]",
          "attn_out_projected": "[B, T, hidden_size]"
        },
        "mlp": {
          "gate_local": "[B, T, intermediate_size/tp]",
          "up_local": "[B, T, intermediate_size/tp]",
          "ffn_down_out": "[B, T, hidden_size]"
        },
        "model_output": "[B, T, vocab_size]"
      },
      "deepseek_v2_tp_model_interfaces": {
        "source_impl": [
          "engine/models/deepseek_v2.py",
          "engine/tp_layers/moe.py"
        ],
        "decoder_input_hidden": "[B, T, hidden_size]",
        "mla_attention": {
          "q_a_proj_out_replicated": "[B, T, q_lora_rank] or skip when q_lora_rank is None",
          "q_b_local": "[B, T, num_heads/tp, qk_nope_head_dim + qk_rope_head_dim]",
          "kv_a_latent_replicated": "[B, T, kv_lora_rank]",
          "k_pe_replicated": "[B, T, qk_rope_head_dim]",
          "kv_b_local": "[B, T, num_heads/tp, qk_nope_head_dim + v_head_dim]",
          "attn_out_local": "[B, T, num_heads/tp * v_head_dim]",
          "attn_out_projected": "[B, T, hidden_size]"
        },
        "dense_mlp": {
          "gate_local": "[B, T, intermediate_size/tp]",
          "up_local": "[B, T, intermediate_size/tp]",
          "down_out": "[B, T, hidden_size]"
        },
        "moe_mlp": {
          "router_logits_replicated": "[B*T, n_routed_experts]",
          "topk_idx": "[B*T, top_k]",
          "topk_weight": "[B*T, top_k]",
          "local_expert_out_flat": "[B*T, hidden_size]",
          "global_expert_out_after_all_reduce": "[B*T, hidden_size]",
          "shared_experts_out": "[B, T, hidden_size] (if n_shared_experts > 0)",
          "moe_final_out": "[B, T, hidden_size]"
        },
        "model_output": "[B, T, vocab_size]"
      },
      "deepseek_v2_mla_kv_contract": {
        "config_dims": {
          "kv_lora_rank": 512,
          "qk_nope_head_dim": 128,
          "qk_rope_head_dim": 64,
          "q_head_dim": 192,
          "v_head_dim": 128,
          "num_attention_heads": 16,
          "num_hidden_layers": 27
        },
        "hf_materialized_kv_shapes_per_layer": {
          "key_states": "[batch, num_heads, q_len, q_head_dim] -> [batch, 16, q_len, 192]",
          "value_states": "[batch, num_heads, q_len, v_head_dim] -> [batch, 16, q_len, 128]"
        },
        "logical_kv_bytes": {
          "formula": "num_layers * num_heads * (q_head_dim + v_head_dim) * dtype_bytes",
          "dtype_bfloat16_bytes_per_token": 276480,
          "bytes_per_block_block_size_16": 4423680
        },
        "physical_block_indexing": {
          "token_to_block": "block_index = token_pos // block_size",
          "token_offset": "offset = token_pos % block_size",
          "slot_id": "slot_id = block_table[block_index] * block_size + offset",
          "block_table_dtype": "python list[int] (若转 tensor 用 int32)"
        },
        "device_dtype_requirements": {
          "runner_inputs": "int64 on cuda",
          "model_weights": "bfloat16 on cuda",
          "kv_placeholder": "bfloat16 on cuda",
          "sampler_logits_compute": "logits.float() before temperature/top_p"
        }
      }
    }
    },
