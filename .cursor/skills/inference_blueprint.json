  "model_layer": {
    "architecture_knowledge_base": {
    "global_primitives_constraints": {
      "rmsnorm_precision_law": {
        "directive": "RMSNorm 在 fp16/bf16 下计算方差前必须先转 float32，归一化后再 cast 回输入 dtype。",
        "reference_pattern": "x_fp32 = x.float(); var = x_fp32.pow(2).mean(-1, keepdim=True); out = (x_fp32 * rsqrt(var + eps) * weight).to(x.dtype)",
        "why": "避免半精度方差计算溢出与 logits 漂移。",
        "source_refs": [
          "notebooks-cn/06_experience/01_task10_tp_qwen_debug_experience.md",
          "notebooks-cn/04_parallel_strategies/02_qwen_dense_tp_implementation_guide.md"
        ]
      },
      "tp_linear_load_no_double_shard": {
        "directive": "ColumnParallelLinear/RowParallelLinear 的 load_weight_shard 必须先做形状拦截。",
        "hard_rule": [
          "若传入权重 shape == self.weight.shape，则直接 copy_。",
          "仅当传入权重是全量张量时，才可按 tp_rank 执行切片。"
        ],
        "why": "磁盘惰性加载（safe_open.get_slice）常已预切分；再次切分会导致双重切片和权重错乱。",
        "source_refs": [
          "notebooks-cn/06_experience/01_task10_tp_qwen_debug_experience.md",
          "notebooks-cn/08_history_prompt/task10从QwenTP到dsTP验证.txt"
        ]
      },
      "hf_baseline_test_oom_guard": {
        "directive": "torchrun 多进程对齐测试时，HF 基准模型严禁 .to(device) 常驻 GPU。",
        "hard_rule": [
          "HF 模型保持 CPU 驻留。",
          "仅在 forward 时将 input_ids/attention_mask 放到目标设备。",
          "必要时调用 torch.cuda.empty_cache() 清理碎片。"
        ],
        "why": "避免 N 进程重复占用全量显存导致 OOM。",
        "source_refs": [
          "notebooks-cn/08_history_prompt/task10从QwenTP到dsTP验证.txt",
          "notebooks-cn/06_experience/02_task11_deepseek_tp_real_debug_experience.md"
        ]
      },
      "debug_evidence_before_guessing": {
