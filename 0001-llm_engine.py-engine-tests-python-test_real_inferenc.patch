-    def __init__(self, config):
-        # 路由专家（同上）
-        self.gate = Linear(hidden_size, num_experts, bias=False)
-        self.experts = FusedMoE(...)
-
-        # 共享专家：一个普通的 MLP，对所有 token 都执行
